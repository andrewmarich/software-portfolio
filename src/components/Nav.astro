---
import ScrollProgress from "../islands/ScrollProgress.tsx";
import AchievementNav from "../islands/AchievementNav.tsx";

const links = [
  { href: "#about", label: "About" },
  { href: "#projects", label: "Projects" },
  { href: "#experience", label: "Experience" },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-[var(--z-nav)] border-b border-screen-raised/30 backdrop-blur-md bg-screen-void/80"
>
  <div class="max-w-6xl mx-auto px-6 hidden md:grid grid-cols-3 items-center h-14">
    <!-- Left: Logo -->
    <a
      href="#"
      class="font-mono text-sm text-glow-amber tracking-wide hover:glow-text--amber transition-all"
    >
      marich.dev
    </a>

    <!-- Center: Nav links + CTA -->
    <div class="flex items-center justify-center gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="font-mono text-xs text-text-muted hover:text-glow-amber transition-colors tracking-wide uppercase"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="font-mono text-xs text-glow-amber border border-glow-amber/40 px-3 py-1 rounded
               hover:bg-glow-amber/10 transition-all tracking-wide uppercase"
      >
        Contact
      </a>
    </div>

    <!-- Right: Gamification -->
    <div class="flex items-center justify-end gap-3">
      <ScrollProgress client:load />
      <AchievementNav client:idle />
    </div>
  </div>

  <!-- Mobile header -->
  <div class="md:hidden flex items-center justify-between h-14 px-6">
    <a
      href="#"
      class="font-mono text-sm text-glow-amber tracking-wide hover:glow-text--amber transition-all"
    >
      marich.dev
    </a>
    <div class="flex items-center gap-3">
      <AchievementNav client:idle />
      <button
      id="mobile-menu-toggle"
      class="text-text-muted hover:text-glow-amber transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 20 20"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <line x1="3" y1="5" x2="17" y2="5"></line>
        <line x1="3" y1="10" x2="17" y2="10"></line>
        <line x1="3" y1="15" x2="17" y2="15"></line>
      </svg>
    </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-screen-raised/50 bg-screen-void/95 backdrop-blur-md"
  >
    <div class="px-6 py-4 flex flex-col gap-3">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="mobile-link font-mono text-sm text-text-muted hover:text-glow-amber transition-colors tracking-wide uppercase"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="mobile-link font-mono text-sm text-glow-amber tracking-wide uppercase"
      >
        Contact
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    const expanded = !menu?.classList.contains("hidden");
    toggle?.setAttribute("aria-expanded", String(expanded));
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
