---
import ScrollProgress from "../islands/ScrollProgress.tsx";
import AchievementNav from "../islands/AchievementNav.tsx";
import { ACHIEVEMENTS } from "../islands/achievement-data";

const links = [
  { href: "#about", label: "About" },
  { href: "#projects", label: "Projects" },
  { href: "#experience", label: "Experience" },
];
---

<nav
  class="border-screen-raised/60 bg-screen-void/95 fixed top-0 right-0 left-0 z-[var(--z-nav)] border-b backdrop-blur-md"
>
  <div class="mx-auto hidden h-14 max-w-6xl grid-cols-3 items-center px-6 md:grid">
    <!-- Left: Logo -->
    <a
      href="#hero"
      class="text-glow-primary hover:glow-text--primary font-mono text-sm tracking-wide transition-all"
    >
      marich.dev
    </a>

    <!-- Center: Nav links + CTA -->
    <div class="flex items-center justify-center gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-text-muted hover:text-glow-primary font-mono text-xs tracking-wide uppercase transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="text-glow-primary border-glow-primary/40 hover:bg-glow-primary/10 rounded border px-3 py-1 font-mono text-xs tracking-wide uppercase transition-all"
      >
        Contact
      </a>
    </div>

    <!-- Right: Gamification -->
    <div class="flex items-center justify-end gap-3">
      <ScrollProgress client:idle />
      <AchievementNav achievements={ACHIEVEMENTS} client:idle />
    </div>
  </div>

  <!-- Mobile header -->
  <div class="flex h-14 items-center justify-between px-6 md:hidden">
    <a
      href="#hero"
      class="text-glow-primary hover:glow-text--primary font-mono text-sm tracking-wide transition-all"
    >
      marich.dev
    </a>
    <div class="flex items-center gap-3">
      <AchievementNav achievements={ACHIEVEMENTS} client:idle />
      <button
        id="mobile-menu-toggle"
        class="text-text-muted hover:text-glow-primary transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <line x1="3" y1="5" x2="17" y2="5"></line>
          <line x1="3" y1="10" x2="17" y2="10"></line>
          <line x1="3" y1="15" x2="17" y2="15"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="border-screen-raised/50 bg-screen-void/95 hidden border-t backdrop-blur-md md:hidden"
  >
    <div class="flex flex-col gap-3 px-6 py-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="mobile-link text-text-muted hover:text-glow-primary font-mono text-sm tracking-wide uppercase transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="mobile-link text-glow-primary font-mono text-sm tracking-wide uppercase"
      >
        Contact
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
    const expanded = !menu?.classList.contains("hidden");
    toggle?.setAttribute("aria-expanded", String(expanded));
  });

  // Close mobile menu on link click
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
