---
interface SkillGroup {
  label: string;
  skills: string[];
}

const groups: SkillGroup[] = [
  {
    label: "Frontend",
    skills: ["TypeScript", "React", "TanStack", "Tailwind CSS", "HTMX", "Bootstrap", "Astro"],
  },
  {
    label: "Backend",
    skills: ["Python", "Django", "Node.js", "PostgreSQL", "Redis", "Drizzle ORM"],
  },
  {
    label: "Infrastructure",
    skills: ["AWS", "GCP", "Cloudflare", "Docker", "Terraform"],
  },
  {
    label: "Integrations",
    skills: ["Stripe", "Twilio", "HubSpot", "DocuSign"],
  },
  {
    label: "AI Tooling",
    skills: ["Claude Code", "ChatGPT / Codex", "Warp", "Local LLMs"],
  },
  {
    label: "Tools",
    skills: ["Git", "GitHub", "GitLab", "CI/CD", "Bun", "Linear", "Notion", "Asana", "Trello"],
  },
];
---

<section id="skills" class="relative py-16 lg:py-24 overflow-hidden">
  <!-- Ambient glow -->
  <div
    class="glow-pool glow-pool--cyan"
    style="width: 500px; height: 500px; top: 50%; left: -200px; transform: translateY(-50%);"
  >
  </div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <p class="section-header mb-12">
      <span class="text-glow-amber">&gt;</span> ls skills/
    </p>

    <div class="grid sm:grid-cols-2 gap-8">
      {
        groups.map((group, i) => (
          <div class="stagger-child" style={`--stagger: ${i}`}>
            <h3 class="font-mono text-sm text-text-faint uppercase tracking-wider mb-4">
              [{group.label}]
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class="pixel-tag rounded">{skill}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
