---
const links = [
  {
    label: "Email",
    href: "mailto:andrew@marich.dev",
    display: "andrew@marich.dev",
  },
  {
    label: "GitHub",
    href: "https://github.com/andrewmarich",
    display: "github.com/andrewmarich",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/andrewmarich",
    display: "linkedin.com/in/andrewmarich",
  },
];
---

<section id="contact" class="relative py-16 lg:py-24">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <p class="section-header mb-6">
      <span class="text-glow-amber">&gt;</span> ping andrew
    </p>

    <h2 class="text-3xl sm:text-4xl font-semibold mb-4">
      Let's build something.
    </h2>

    <p class="text-text-muted max-w-lg mb-10 leading-relaxed">
      Got a project in mind, a role to fill, or just want to talk tech?
      Reach out.
    </p>

    <div class="space-y-4">
      {
        links.map((link) => (
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:gap-4">
            <span class="font-mono text-xs text-text-faint uppercase tracking-wider sm:w-20 sm:shrink-0 mb-1 sm:mb-0">
              {link.label}
            </span>
            <a
              href={link.href}
              target={link.href.startsWith("mailto") ? undefined : "_blank"}
              rel={link.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
              class="font-mono text-sm text-text-muted glow-underline break-all sm:break-normal"
            >
              {link.display}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
