---
const links = [
  {
    label: "Email",
    href: "mailto:marich.andrew@outlook.com",
    display: "marich.andrew@outlook.com",
  },
  {
    label: "GitHub",
    href: "https://github.com/andrewmarich",
    display: "github.com/andrewmarich",
  },
  {
    label: "LinkedIn",
    href: "https://linkedin.com/in/andrewmarich",
    display: "linkedin.com/in/andrewmarich",
  },
];
---

<section id="contact" class="relative py-24 lg:py-32">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <p class="section-header mb-6">
      <span class="text-glow-amber">&gt;</span> ping andrew
    </p>

    <h2 class="text-3xl sm:text-4xl font-semibold mb-4">
      Let's build something.
    </h2>

    <p class="text-text-muted max-w-lg mb-10 leading-relaxed">
      I'm always open to interesting conversations, collaboration
      opportunities, or just talking shop. Drop me a line.
    </p>

    <div class="space-y-4">
      {
        links.map((link) => (
          <div class="flex items-baseline gap-4">
            <span class="font-mono text-xs text-text-faint uppercase tracking-wider w-20 shrink-0">
              {link.label}
            </span>
            <a
              href={link.href}
              target={link.href.startsWith("mailto") ? undefined : "_blank"}
              rel={link.href.startsWith("mailto") ? undefined : "noopener noreferrer"}
              class="font-mono text-sm text-text-muted glow-underline"
            >
              {link.display}
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>
