---
import { Image } from "astro:assets";
import leadsDashboard from "../assets/images/leads-dashboard.webp";
import balanceDashboard from "../assets/images/balance-dashboard.webp";
import portfolioScreenshot from "../assets/images/portfolio-screenshot.webp";

interface Project {
  name: string;
  subtitle: string;
  description: string;
  tags: string[];
  image: ImageMetadata;
  accent: string;
  accentRgb: string;
}

const projects: Project[] = [
  {
    name: "Lead Validation Engine",
    subtitle: "B1 Marketing Group",
    description:
      "Lead intake and routing system for legal services. Call center agents fill out dynamic forms, the system validates and enriches data through third-party APIs, then routes qualified leads to the right vendors. Built with HIPAA compliance baked in.",
    tags: ["Django", "PostgreSQL", "HTMX", "Bootstrap", "AWS", "Docker", "Redis", "DocuSign"],
    image: leadsDashboard,
    accent: "oklch(64% .204 222)",
    accentRgb: "14,165,233",
  },
  {
    name: "Medical Billing Platform",
    subtitle: "Balance",
    description:
      "Accounts receivable platform for medical and dental practices. Handles invoicing, payment collection through Stripe, patient follow-ups via SMS, and bulk operations. Runs on the edge through Cloudflare Workers.",
    tags: ["React", "TanStack", "PostgreSQL", "Cloudflare Workers", "GCP", "Stripe", "Twilio"],
    image: balanceDashboard,
    accent: "#8b5cf6",
    accentRgb: "139,92,246",
  },
  {
    name: "Software Portfolio",
    subtitle: "marich.dev",
    description:
      "The site you're on right now. Mostly static with React islands where interactivity matters. Has a few things hidden around if you like poking at websites.",
    tags: ["Astro", "React", "TypeScript", "Tailwind CSS 4", "Cloudflare Pages"],
    image: portfolioScreenshot,
    accent: "#ff2d6f",
    accentRgb: "255,45,111",
  },
];
---

<section id="projects" class="relative section-padding overflow-hidden">
  <!-- Ambient glow -->
  <div class="glow-pool glow-pool--primary glow-pool--right-center"></div>

  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <p class="section-header mb-12">
      <span class="text-glow-primary">&gt;</span> ls projects/
    </p>

    <!-- Project cards -->
    <div class="space-y-6">
      {
        projects.map((project, i) => (
          <article
            class="stagger-child relative bg-screen-panel/50 border border-screen-raised/20 rounded-lg p-6 lg:p-8
                   transition-all duration-300"
            style={`--accent: ${project.accent}; --accent-rgb: ${project.accentRgb}; --stagger: ${i}`}
            data-hover-glow
          >
            <div class="flex flex-col lg:flex-row gap-6">
              <!-- Project image -->
              <div class="crt-hover rounded-md overflow-hidden bg-screen-dark border border-screen-raised/50
                          w-full lg:w-80 shrink-0 relative">
                <Image
                  src={project.image}
                  alt={`${project.name} screenshot`}
                  width={1200}
                  height={657}
                  class="w-full h-auto block"
                  loading="lazy"
                />
              </div>

              <!-- Project info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-1">
                  <div class="w-2 h-2 rounded-full" style={`background: ${project.accent};`} />
                  <h3 class="font-semibold text-xl" style={`color: ${project.accent};`}>
                    {project.name}
                  </h3>
                </div>

                <p class="font-mono text-xs text-text-faint mb-3 uppercase tracking-wider pl-5">
                  {project.subtitle}
                </p>

                <p class="text-text-muted leading-relaxed mb-4">
                  {project.description}
                </p>

                <!-- Tech tags -->
                <div class="flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="pixel-tag rounded">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
