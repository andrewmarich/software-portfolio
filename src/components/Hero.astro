---

---

<section id="hero" class="relative flex min-h-screen items-center overflow-hidden pb-32">
  <div class="glow-pool glow-pool--primary glow-pool--top-right"></div>
  <div class="glow-pool glow-pool--cyan glow-pool--bottom-left"></div>

  <div class="atmosphere-dots absolute inset-0 opacity-[0.03]"></div>

  <div class="relative z-10 mx-auto w-full max-w-6xl px-6">
    <div class="max-w-2xl">
      <p class="text-text-faint mb-4 font-mono text-sm tracking-wide">
        <span class="text-glow-primary">~</span> hello, world
      </p>

      <h1 class="mb-4 text-5xl font-semibold tracking-tight sm:text-6xl lg:text-7xl">
        Andrew<br />
        <span class="text-glow-primary">Marich</span>
      </h1>

      <p class="text-text-muted mb-6 font-mono text-lg sm:text-xl">
        <span class="text-glow-primary">&gt;</span> full-stack engineer<span class="cursor-blink"
        ></span>
      </p>

      <p class="text-text-muted mb-10 max-w-lg text-lg leading-relaxed">
        Building things across the stack. Cloud infrastructure, internal tooling, and the interfaces
        people actually use.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="#projects"
          class="group bg-screen-raised border-screen-raised text-text-bright glow-hover hover:text-glow-primary inline-flex items-center gap-2 rounded border px-6 py-3 font-mono text-sm transition-all"
        >
          See my work
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-y-0.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
        <a
          href="#contact"
          class="border-text-faint text-text-muted hover:border-glow-primary hover:text-glow-primary inline-flex items-center gap-2 rounded border px-6 py-3 font-mono text-sm transition-all"
        >
          Get in touch
        </a>
      </div>
    </div>
  </div>
</section>
