---

---

<section
  id="hero"
  class="relative min-h-screen flex items-center overflow-hidden pb-32"
>
  <div class="glow-pool glow-pool--primary glow-pool--top-right"></div>
  <div class="glow-pool glow-pool--cyan glow-pool--bottom-left"></div>

  <div class="absolute inset-0 atmosphere-dots opacity-[0.03]"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
    <div class="max-w-2xl">
      <p class="font-mono text-sm text-text-faint mb-4 tracking-wide">
        <span class="text-glow-primary">~</span> hello, world
      </p>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-semibold tracking-tight mb-4">
        Andrew<br />
        <span class="text-glow-primary">Marich</span>
      </h1>

      <p class="font-mono text-lg sm:text-xl text-text-muted mb-6">
        <span class="text-glow-primary">&gt;</span> full-stack engineer<span
          class="cursor-blink"></span>
      </p>

      <p class="text-text-muted text-lg max-w-lg mb-10 leading-relaxed">
        Building things across the stack. Cloud infrastructure, internal
        tooling, and the interfaces people actually use.
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href="#projects"
          class="group inline-flex items-center gap-2 px-6 py-3 font-mono text-sm
                 bg-screen-raised border border-screen-raised text-text-bright
                 rounded glow-hover transition-all hover:text-glow-primary"
        >
          See my work
          <svg
            class="w-4 h-4 transition-transform group-hover:translate-y-0.5"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-3 font-mono text-sm
                 border border-text-faint text-text-muted
                 rounded hover:border-glow-primary hover:text-glow-primary transition-all"
        >
          Get in touch
        </a>
      </div>
    </div>
  </div>

</section>
