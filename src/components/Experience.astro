---
interface Role {
  company: string;
  title: string;
  period: string;
  location: string;
  bullets: string[];
}

const roles: Role[] = [
  {
    company: "B1 Marketing Group",
    title: "Full-Stack Engineer | Cloud & Infrastructure",
    period: "Jul 2025 – Present",
    location: "Gilbert, AZ",
    bullets: [
      "Own the frontend across all products. UI/UX design, component development, and making sure what ships looks and works the way it should.",
      "Build and maintain API integrations across the platform. HubSpot, DocuSign, Twilio, and several third-party data vendors all connected through services I built.",
      "Set up the company's cloud infrastructure, identity management, and dev tooling from scratch.",
      "Act as the team's QA layer. Review every PR, catch issues before they ship, and keep the codebase clean.",
    ],
  },
  {
    company: "Balance",
    title: "CTO & Co-founder",
    period: "Aug 2020 – Present",
    location: "Greater Phoenix Area",
    bullets: [
      "Co-founded a medical billing platform with two partners. I'm the sole engineer, they handle the business and clinical side.",
      "Built the full stack on React 19, TanStack, Cloudflare Workers, and Google Cloud. Client 30-day collections went from 30% to 70%.",
      "Make all the technology calls. Stack, infrastructure, vendors, compliance, roadmap.",
    ],
  },
  {
    company: "Devize",
    title: "Product Builder",
    period: "Oct 2024 – Jul 2025",
    location: "Gilbert, AZ",
    bullets: [
      "Took 7+ web applications from idea to launch. Requirements, design, build, deploy, iterate.",
      "Backend work across relational schemas, auth flows, and API integrations with Stripe, Twilio, and GCP.",
      "Managed backlogs in Notion and Linear. Triaged bugs, prioritized features, kept things moving.",
    ],
  },
];

interface Education {
  school: string;
  degree: string;
  year: string;
}

const education: Education[] = [
  {
    school: "Western Governors University",
    degree: "BS, Computer Science",
    year: "2024",
  },
  {
    school: "University of Arizona",
    degree: "BS, Finance",
    year: "2019",
  },
];

const certifications = ["Linux Essentials", "ITIL Foundation", "HIPAA Compliance"];
---

<section id="experience" class="relative section-padding">
  <div class="max-w-6xl mx-auto px-6">
    <!-- Section header -->
    <p class="section-header mb-12">
      <span class="text-glow-amber">&gt;</span> experience
    </p>

    <!-- Timeline -->
    <div class="relative">
      <!-- Timeline line -->
      <div
        class="absolute left-[7px] top-2 bottom-2 w-px hidden lg:block"
        style="background: repeating-linear-gradient(
          to bottom,
          var(--color-screen-raised) 0px,
          var(--color-screen-raised) 4px,
          transparent 4px,
          transparent 8px
        );"
      >
      </div>

      <div class="space-y-12">
        {
          roles.map((role, i) => (
            <div class="stagger-child relative lg:pl-10" style={`--stagger: ${i}`}>
              {/* Timeline node — amber LED */}
              <div class="hidden lg:block absolute left-0 top-1.5 w-[15px] h-[15px]">
                <div class="w-full h-full rounded-full bg-screen-dark border-2 border-glow-amber/50" />
                <div class="absolute inset-1 rounded-full bg-glow-amber/30" />
              </div>

              {/* Role content */}
              <div>
                <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-3 mb-1">
                  <h3 class="text-text-bright font-semibold text-lg">
                    {role.company}
                  </h3>
                  <span class="font-mono text-xs text-text-faint">
                    {role.period}
                  </span>
                </div>

                <p class="font-mono text-sm text-glow-amber/80 mb-1">
                  {role.title}
                </p>
                <p class="text-text-faint text-sm mb-4">{role.location}</p>

                <ul class="space-y-2">
                  {role.bullets.map((bullet) => (
                    <li class="text-text-muted text-sm leading-relaxed pl-4 relative before:content-['▸'] before:absolute before:left-0 before:text-text-faint before:text-xs">
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Education -->
    <div id="education" class="mt-20 scroll-mt-20">
      <p class="section-header mb-8">
        <span class="text-glow-amber">&gt;</span> education
      </p>

      <div class="grid sm:grid-cols-2 gap-6">
        {
          education.map((edu, i) => (
            <div class="stagger-child bg-screen-panel/30 border border-screen-raised/50 rounded-lg p-5" style={`--stagger: ${i + 3}`}>
              <h4 class="text-text-bright font-medium mb-1">{edu.school}</h4>
              <p class="font-mono text-sm text-text-muted">{edu.degree}</p>
              <p class="font-mono text-xs text-text-faint mt-1">{edu.year}</p>
            </div>
          ))
        }
      </div>

      <!-- Certifications -->
      <div class="mt-6 flex flex-wrap gap-2">
        {
          certifications.map((cert) => (
            <span class="pixel-tag rounded">{cert}</span>
          ))
        }
      </div>
    </div>
  </div>
</section>
