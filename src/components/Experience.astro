---
import SectionHeader from "./SectionHeader.astro";

interface Role {
  company: string;
  title: string;
  period: string;
  location: string;
  bullets: string[];
}

const roles: Role[] = [
  {
    company: "B1 Marketing Group",
    title: "Full-Stack Engineer | Cloud & Infrastructure",
    period: "Jul 2025 – Present",
    location: "Gilbert, AZ",
    bullets: [
      "Own the frontend across all products. UI/UX design, component development, and making sure what ships looks and works the way it should.",
      "Build and maintain API integrations across the platform. HubSpot, DocuSign, Twilio, and several third-party data vendors all connected through services I built.",
      "Set up the company's cloud infrastructure, identity management, and dev tooling from scratch.",
      "Act as the team's QA layer. Review every PR, catch issues before they ship, and keep the codebase clean.",
    ],
  },
  {
    company: "Balance",
    title: "CTO & Co-Founder",
    period: "Aug 2020 – Present",
    location: "Greater Phoenix Area",
    bullets: [
      "Co-founded a medical billing platform with two partners. I'm the sole engineer, they handle the business and clinical side.",
      "Built the full stack on React 19, TanStack, Cloudflare Workers, and Google Cloud. Client 30-day collections went from 30% to 70%.",
      "Make all the technology calls. Stack, infrastructure, vendors, compliance, roadmap.",
    ],
  },
  {
    company: "Devize",
    title: "Product Builder",
    period: "Oct 2024 – Jul 2025",
    location: "Gilbert, AZ",
    bullets: [
      "Took 7+ web applications from idea to launch. Requirements, design, build, deploy, iterate.",
      "Backend work across relational schemas, auth flows, and API integrations with Stripe, Twilio, and GCP.",
      "Managed backlogs in Notion and Linear. Triaged bugs, prioritized features, kept things moving.",
    ],
  },
];

interface Education {
  school: string;
  degree: string;
  year: string;
}

const education: Education[] = [
  {
    school: "Western Governors University",
    degree: "BS, Computer Science",
    year: "2024",
  },
  {
    school: "University of Arizona",
    degree: "BS, Finance",
    year: "2019",
  },
];

const certifications = ["Linux Essentials", "ITIL Foundation", "HIPAA Associate"];
---

<section id="experience" class="section-padding relative" aria-labelledby="experience-heading">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeader id="experience" label="experience" />

    <div class="relative">
      <div
        class="absolute top-2 bottom-2 left-[7px] hidden w-px lg:block"
        style="background: repeating-linear-gradient(
          to bottom,
          var(--color-screen-raised) 0px,
          var(--color-screen-raised) 4px,
          transparent 4px,
          transparent 8px
        );"
      >
      </div>

      <div class="space-y-12">
        {
          roles.map((role, i) => (
            <div class="stagger-child relative lg:pl-10" style={`--stagger: ${i}`}>
              {/* Timeline node — amber LED */}
              <div class="absolute top-1.5 left-0 hidden h-[15px] w-[15px] lg:block">
                <div class="bg-screen-dark border-glow-primary/50 h-full w-full rounded-full border-2" />
                <div class="bg-glow-primary/30 absolute inset-1 rounded-full" />
              </div>

              {/* Role content */}
              <div>
                <div class="mb-1 flex flex-col gap-1 sm:flex-row sm:items-baseline sm:gap-3">
                  <h3 class="text-text-bright text-lg font-semibold">{role.company}</h3>
                  <span class="text-text-faint font-mono text-xs">{role.period}</span>
                </div>

                <p class="text-glow-primary/80 mb-1 font-mono text-sm">{role.title}</p>
                <p class="text-text-faint mb-4 text-sm">{role.location}</p>

                <ul class="space-y-2">
                  {role.bullets.map((bullet) => (
                    <li class="text-text-muted before:text-text-faint relative pl-4 text-sm leading-relaxed before:absolute before:left-0 before:text-xs before:content-['▸']">
                      {bullet}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <section id="education" class="mt-20 scroll-mt-20" aria-labelledby="education-heading">
      <SectionHeader id="education" label="education" class="mb-8" />

      <div class="grid gap-6 sm:grid-cols-2">
        {
          education.map((edu, i) => (
            <div
              class="stagger-child bg-screen-panel/30 border-screen-raised/50 rounded-lg border p-5"
              style={`--stagger: ${i + 3}`}
            >
              <h3 class="text-text-bright mb-1 font-medium">{edu.school}</h3>
              <p class="text-text-muted font-mono text-sm">{edu.degree}</p>
              <p class="text-text-faint mt-1 font-mono text-xs">{edu.year}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-6 flex flex-wrap gap-2">
        {certifications.map((cert) => <span class="pixel-tag rounded">{cert}</span>)}
      </div>
    </section>
  </div>
</section>
