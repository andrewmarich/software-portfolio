---
const year = new Date().getFullYear();
---

<footer class="border-screen-raised/30 border-t py-8">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 sm:flex-row">
    <p class="text-text-faint font-mono text-xs">
      &copy; {year} Andrew Marich
    </p>
    <p class="text-text-faint font-mono text-xs">
      Built with <span class="text-glow-primary">Astro</span> + caffeine
    </p>
  </div>
</footer>
