---
import Base from "../layouts/Base.astro";
---

<Base title="You found it — marich.dev/secret">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="max-w-sm w-full text-center">
      <!-- Pixel chest SVG -->
      <div class="relative mx-auto mb-8 w-fit">
        <div class="absolute inset-0 blur-2xl bg-glow-amber/15 rounded-full scale-150"></div>
        <svg
          width="120"
          height="108"
          viewBox="0 0 20 18"
          class="relative"
          style="image-rendering: pixelated;"
        >
        <!-- Lid -->
        <rect x="1" y="0" width="18" height="2" fill="var(--color-glow-amber)" />
        <rect x="0" y="2" width="20" height="3" fill="var(--color-glow-amber)" />
        <rect x="8" y="2" width="4" height="3" fill="var(--color-screen-void)" />
        <!-- Keyhole -->
        <rect x="9" y="3" width="2" height="1" fill="var(--color-glow-amber)" />
        <!-- Body -->
        <rect x="0" y="5" width="1" height="1" fill="var(--color-screen-void)" />
        <rect x="19" y="5" width="1" height="1" fill="var(--color-screen-void)" />
        <rect x="0" y="6" width="20" height="1" rx="0" fill="var(--color-text-faint)" opacity="0.3" />
        <rect x="0" y="5" width="20" height="12" fill="var(--color-glow-amber)" opacity="0.7" />
        <rect x="1" y="6" width="18" height="10" fill="var(--color-screen-dark)" />
        <rect x="0" y="16" width="20" height="2" fill="var(--color-glow-amber)" />
        <!-- Latch -->
        <rect x="9" y="5" width="2" height="2" fill="var(--color-glow-amber)" />
        <!-- Trim lines -->
        <rect x="2" y="8" width="16" height="1" fill="var(--color-glow-amber)" opacity="0.2" />
        <rect x="2" y="13" width="16" height="1" fill="var(--color-glow-amber)" opacity="0.2" />
      </svg>
      </div>

      <p
        class="font-pixel text-[9px] text-glow-amber tracking-widest uppercase mb-2 animate-pulse"
      >
        You found a secret
      </p>

      <p class="font-mono text-text-muted text-sm mb-10 text-balance">
        The real treasure was the URL you guessed along the way.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 px-5 py-2.5 font-mono text-xs
               border border-text-faint text-text-muted rounded
               hover:border-glow-amber hover:text-glow-amber transition-all"
      >
        ← Return to the overworld
      </a>
    </div>
  </div>
</Base>
