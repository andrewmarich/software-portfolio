---
import Base from "../layouts/Base.astro";
---

<Base title="You found it — marich.dev/secret">
  <div class="flex min-h-screen items-center justify-center px-6">
    <div class="w-full max-w-sm text-center">
      <!-- Pixel chest SVG -->
      <div class="relative mx-auto mb-8 w-fit">
        <div class="bg-glow-primary/15 absolute inset-0 scale-150 rounded-full blur-2xl"></div>
        <svg
          width="120"
          height="108"
          viewBox="0 0 20 18"
          class="relative"
          style="image-rendering: pixelated;"
        >
          <!-- Lid -->
          <rect x="1" y="0" width="18" height="2" fill="var(--color-glow-primary)"></rect>
          <rect x="0" y="2" width="20" height="3" fill="var(--color-glow-primary)"></rect>
          <rect x="8" y="2" width="4" height="3" fill="var(--color-screen-void)"></rect>
          <!-- Keyhole -->
          <rect x="9" y="3" width="2" height="1" fill="var(--color-glow-primary)"></rect>
          <!-- Body -->
          <rect x="0" y="5" width="1" height="1" fill="var(--color-screen-void)"></rect>
          <rect x="19" y="5" width="1" height="1" fill="var(--color-screen-void)"></rect>
          <rect
            x="0"
            y="6"
            width="20"
            height="1"
            rx="0"
            fill="var(--color-text-faint)"
            opacity="0.3"></rect>
          <rect x="0" y="5" width="20" height="12" fill="var(--color-glow-primary)" opacity="0.7"
          ></rect>
          <rect x="1" y="6" width="18" height="10" fill="var(--color-screen-dark)"></rect>
          <rect x="0" y="16" width="20" height="2" fill="var(--color-glow-primary)"></rect>
          <!-- Latch -->
          <rect x="9" y="5" width="2" height="2" fill="var(--color-glow-primary)"></rect>
          <!-- Trim lines -->
          <rect x="2" y="8" width="16" height="1" fill="var(--color-glow-primary)" opacity="0.2"
          ></rect>
          <rect x="2" y="13" width="16" height="1" fill="var(--color-glow-primary)" opacity="0.2"
          ></rect>
        </svg>
      </div>

      <p
        class="font-pixel text-glow-primary mb-2 animate-pulse text-[9px] tracking-widest uppercase"
      >
        You found a secret
      </p>

      <p class="text-text-muted mb-10 font-mono text-sm text-balance">
        The real treasure was the URL you guessed along the way.
      </p>

      <a
        href="/"
        class="border-text-faint text-text-muted hover:border-glow-primary hover:text-glow-primary inline-flex items-center gap-2 rounded border px-5 py-2.5 font-mono text-xs transition-all"
      >
        ← Return to the overworld
      </a>
    </div>
  </div>
</Base>
