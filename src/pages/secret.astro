---
import Base from "../layouts/Base.astro";
---

<Base title="You found it — marich.dev/secret">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="max-w-lg text-center">
      <p
        class="font-pixel text-[10px] text-glow-amber tracking-widest uppercase mb-8 animate-pulse"
      >
        Secret Area Discovered
      </p>

      <div class="bg-screen-panel/50 border border-screen-raised/50 rounded-lg p-8 mb-8">
        <pre
          class="font-mono text-xs sm:text-sm text-text-muted leading-relaxed text-left"
        >
{`> cat /home/andrew/.profile

NAME="Andrew Marich"
CLASS="Full-Stack Engineer"
ORIGIN="Finance → CS"
ALIGNMENT="Chaotic Good"
WEAKNESS="Sushi, retro games"
COMPANION_1="Labrador (golden)"
COMPANION_2="Labrador (chocolate)"
COMPANION_3="Daughter (legendary)"

CURRENT_QUEST="Build something great"
SAVE_FILE_CORRUPTED=false
ACCEPTING_QUESTS=true`}
        </pre>
      </div>

      <p class="text-text-faint font-mono text-xs mb-6">
        You found 1 of the hidden pages. Are there more? Maybe.
      </p>

      <a
        href="/"
        class="inline-flex items-center gap-2 px-5 py-2.5 font-mono text-sm
               border border-text-faint text-text-muted rounded
               hover:border-glow-amber hover:text-glow-amber transition-all"
      >
        ← Return to the overworld
      </a>
    </div>
  </div>
</Base>
