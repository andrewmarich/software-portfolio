---
import Base from "../layouts/Base.astro";
---

<Base title="You found it — marich.dev/secret">
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="max-w-lg text-center">
      <!-- Chest ASCII art -->
      <pre
        class="font-mono text-glow-amber text-xs sm:text-sm mb-6 inline-block text-left"
      >
{`    ___________
   /           \\
  /  ▲  ▲  ▲  \\
 /_______________\\
 |               |
 |   ◆  ◆  ◆   |
 |_______________|`}
      </pre>

      <p
        class="font-pixel text-[10px] text-glow-amber tracking-widest uppercase mb-2 animate-pulse"
      >
        You opened the chest!
      </p>

      <p class="font-mono text-neon-cyan text-sm mb-8">
        You got: <span class="text-text-bright">Andrew's Profile</span>
      </p>

      <div class="bg-screen-panel/50 border border-glow-amber/20 rounded-lg p-8 mb-8 text-left">
        <div class="space-y-3 font-mono text-sm">
          <div class="flex justify-between">
            <span class="text-text-faint">Name</span>
            <span class="text-text-bright">Andrew Marich</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-faint">Class</span>
            <span class="text-text-bright">Full-Stack Engineer</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-faint">Origin</span>
            <span class="text-text-bright">Finance → CS</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-faint">Alignment</span>
            <span class="text-text-bright">Chaotic Good</span>
          </div>

          <div class="h-px bg-screen-raised/50 my-2"></div>

          <div class="flex justify-between">
            <span class="text-text-faint">Weakness</span>
            <span class="text-glow-amber">Sushi</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-faint">Companions</span>
            <span class="text-neon-cyan">2 Labs + 1 Daughter</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-faint">Rupees</span>
            <span class="text-phosphor">Not enough</span>
          </div>
          <div class="flex justify-between">
            <span class="text-text-faint">Status</span>
            <span class="text-phosphor">Accepting quests</span>
          </div>
        </div>
      </div>

      <a
        href="/"
        class="inline-flex items-center gap-2 px-5 py-2.5 font-mono text-sm
               border border-text-faint text-text-muted rounded
               hover:border-glow-amber hover:text-glow-amber transition-all"
      >
        ← Return to the overworld
      </a>
    </div>
  </div>
</Base>
