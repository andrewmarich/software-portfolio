---
import Base from "../layouts/Base.astro";
---

<Base title="404 — marich.dev">
  <div class="flex min-h-screen items-center justify-center px-6">
    <div class="text-center">
      <p class="font-pixel text-glow-primary mb-4 text-xl sm:text-2xl">404</p>
      <p class="text-text-muted mb-2 font-mono text-lg">This page doesn't exist yet.</p>
      <p class="text-text-faint mb-8 text-sm">Maybe it's a locked area. Maybe it never was.</p>
      <a
        href="/"
        class="border-text-faint text-text-muted hover:border-glow-primary hover:text-glow-primary inline-flex items-center gap-2 rounded border px-5 py-2.5 font-mono text-sm transition-all"
      >
        ← Back to start
      </a>
    </div>
  </div>
</Base>
